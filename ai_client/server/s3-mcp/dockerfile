# Stage 1 — Build
FROM node:20-alpine AS builder

WORKDIR /app

# Install git and bash for building
RUN apk add --no-cache git bash python3 py3-pip

# Clone your repo (or copy local source)
RUN git clone https://github.com/khuynh22/aws-s3-mcp-server.git .

# Install Node dependencies
RUN npm install
RUN npm install -g typescript

# Build TypeScript
RUN npx tsc

# Stage 2 — Runtime
FROM node:20-alpine

WORKDIR /app

# Copy built JS and package files
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/package*.json ./

# Install runtime dependencies
RUN npm install --omit=dev

# ✅ Install dependencies for AWS CLI
RUN apk add --no-cache python3 py3-pip bash less groff

# ✅ Install AWS CLI via pip (works on Alpine)
RUN pip3 install --upgrade awscli

# ✅ Add AWS CLI to PATH
ENV PATH="/root/.local/bin:$PATH"

# Verify AWS CLI installation (optional)
RUN aws --version

# Run MCP server
CMD ["node", "dist/index.js"]